---
// src/pages/404.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/ui/Section.astro';
import Container from '../components/ui/Container.astro';
import { MapPinOff, ArrowLeft } from 'lucide-astro';
---

<BaseLayout 
  title="Página no encontrada | Gino Cotos" 
  description="Ups, parece que te has perdido. Te guío de vuelta a la rentabilidad operativa."
>

  <Section class="bg-light pt-32 pb-24 md:pt-40 md:pb-32 min-h-[80vh] flex items-center justify-center overflow-hidden relative">
    
    <div class="absolute inset-0 opacity-5 pointer-events-none">
      <MapPinOff class="absolute -top-10 -left-10 w-64 h-64 text-primary" />
      <MapPinOff class="absolute -bottom-20 -right-20 w-80 h-80 text-accent" />
    </div>

    <Container class="max-w-3xl text-center relative z-10">
      
      <div class="flex flex-col items-center mb-10 relative">
        <div class="w-24 h-24 md:w-32 md:h-32 rounded-3xl bg-primary/5 flex items-center justify-center text-accent mb-8 shadow-inner">
          <MapPinOff class="w-12 h-12 md:w-16 md:h-16" stroke-width="1.5" />
        </div>
        <h1 class="text-[100px] md:text-[160px] lg:text-[200px] font-heading font-black text-primary leading-none tracking-tighter relative">
          404
          <span class="absolute top-2 left-2 text-primary/5 -z-10">404</span>
        </h1>
      </div>

      <div class="space-y-6 max-w-xl mx-auto mb-12">
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-primary leading-tight">
          Vaya, parece que te has <span class="text-accent">perdido en la nube.</span>
        </h2>
        <p class="text-xl text-dark/70 leading-relaxed">
          El enlace que seguiste podría estar roto, o la página podría haber sido eliminada. No te preocupes, hasta los mejores sistemas operativos tienen fallos.
        </p>
      </div>

      <div class="flex justify-center mt-8">
        <a 
          href="/" 
          class="flex items-center justify-center gap-3 px-8 py-4 bg-primary text-white font-bold text-lg rounded-xl hover:bg-accent transition-colors duration-300 shadow-lg hover:shadow-xl group"
        >
          <ArrowLeft class="w-5 h-5 group-hover:-translate-x-1 transition-transform" />
          Volver a la Zona de Rentabilidad
        </a>
      </div>

    </Container>
  </Section>

</BaseLayout>