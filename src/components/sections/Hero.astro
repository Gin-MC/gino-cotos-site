---
// src/components/sections/Hero.astro
import Section from '../ui/Section.astro';
import Container from '../ui/Container.astro';
import Badge from '../ui/Badge.astro';
import Button from '../ui/Button.astro';
import { ArrowRight, Terminal } from 'lucide-astro';
---

<Section class="relative pt-32 pb-20 md:pt-40 md:pb-28 overflow-hidden">
  
  <div class="absolute inset-0 -z-10 h-full w-full bg-light bg-[radial-gradient(#e5e7eb_1px,transparent_1px)] [background-size:16px_16px] opacity-50"></div>

  <Container class="relative z-10 text-center">
    <div class="max-w-4xl mx-auto flex flex-col items-center">
      
      <Badge class="mb-8">
        <Terminal class="w-4 h-4" />
        Estratega Tecnológico para Startups
      </Badge>

      <h1 class="text-5xl md:text-6xl lg:text-7xl mb-8 leading-[1.1]">
        Transforma tu caos operativo en <br class="hidden md:block" />
        <span class="text-accent">sistemas automatizados</span>
      </h1>

      <p class="text-lg md:text-xl text-dark/70 mb-10 max-w-2xl leading-relaxed">
        Ayudo a empresas emergentes a optimizar procesos, integrar herramientas y escalar sin perder el control. Ahorra horas de trabajo manual cada semana.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
        <Button href="/contacto" variant="primary" class="text-lg px-8 py-4">
          Agendar Diagnóstico
          <ArrowRight class="w-5 h-5 ml-2" />
        </Button>
        <Button href="/servicios" variant="outline" class="text-lg px-8 py-4 bg-light">
          Explorar Servicios
        </Button>
      </div>

    </div>
  </Container>
</Section>