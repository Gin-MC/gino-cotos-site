---
// src/components/ui/Button.astro
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost';
  class?: string;
  type?: 'button' | 'submit';
}

const { 
  href, 
  variant = 'primary', 
  class: className = '',
  type = 'button'
} = Astro.props;

// Estilos base compartidos
const baseStyles = "inline-flex items-center justify-center px-6 py-3 font-heading font-bold rounded-lg transition-all duration-300 ease-out";

// Variantes usando tu paleta de Tailwind v4
const variants = {
  primary: "bg-accent text-primary hover:bg-[#27ae60] shadow-sm hover:shadow-md hover:-translate-y-0.5",
  secondary: "bg-primary text-light hover:bg-primary/90 shadow-sm",
  outline: "border-2 border-primary text-primary hover:bg-primary hover:text-light",
  ghost: "text-primary hover:bg-primary/5"
};

// Determina qué etiqueta HTML usar
const Element = href ? 'a' : 'button';
---

<Element 
  href={href} 
  type={!href ? type : undefined} 
  class={`${baseStyles} ${variants[variant]} ${className}`}
>
  <slot />
</Element>