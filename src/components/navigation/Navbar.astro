---
// Importamos los iconos
import { Menu, X } from 'lucide-astro';

// Importamos tu logo desde la carpeta assets
import logo from '../../assets/logo.png';

// Obtenemos la URL actual para marcar la página activa
const pathname = Astro.url.pathname;

// Arreglo de navegación
const navLinks = [
  { name: 'Inicio', url: '/' },
  { name: 'Servicios', url: '/servicios' },
  { name: 'Proyectos', url: '/proyectos' },
  { name: 'Sobre mí', url: '/sobre-mi' },
  { name: 'Tutoriales', url: '/contenido/' }, 
];
---

<header class="fixed w-full top-0 z-50 bg-white/90 backdrop-blur-md border-b border-primary/10 transition-all duration-300" id="navbar">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      
      <a href="/" class="flex-shrink-0 flex items-center gap-2 group">
        <img 
          src={logo.src} 
          alt="Gino Cotos Logo" 
          class="h-10 w-auto group-hover:scale-105 transition-transform duration-300" 
        />
      </a>

      <nav class="hidden lg:flex items-center gap-8">
        <ul class="flex gap-8">
          {navLinks.map(link => {
            const currentPath = pathname.replace(/\/$/, "");
            const linkUrl = link.url.replace(/\/$/, "");
            const isActive = currentPath === linkUrl || (linkUrl === "" && currentPath === "");

            return (
              <li>
                <a 
                  href={link.url} 
                  class={`relative font-bold text-sm uppercase tracking-wider py-2 transition-colors duration-300 hover:text-accent group ${isActive ? 'text-accent' : 'text-primary'}`}
                >
                  {link.name}
                  <span class={`absolute left-0 -bottom-1 w-full h-0.5 bg-accent transition-transform duration-300 origin-left ${isActive ? 'scale-x-100' : 'scale-x-0 group-hover:scale-x-100'}`}></span>
                </a>
              </li>
            )
          })}
        </ul>

        <a href="/contacto" class="px-6 py-2.5 bg-primary text-white font-bold rounded-lg hover:bg-accent transition-colors duration-300 shadow-sm hover:shadow-md">
          Contactar
        </a>
      </nav>

      <div class="lg:hidden flex items-center">
        <button id="mobile-menu-btn" class="text-primary hover:text-accent transition-colors p-2 focus:outline-none" aria-label="Abrir menú">
          <Menu class="w-8 h-8" id="menu-icon-open" />
          <X class="w-8 h-8 hidden" id="menu-icon-close" />
        </button>
      </div>

    </div>
  </div>

  <div id="mobile-menu" class="lg:hidden absolute top-20 left-0 w-full bg-white border-b border-primary/10 shadow-2xl hidden flex-col">
    <ul class="flex flex-col px-6 pt-4 pb-8 space-y-2">
      {navLinks.map(link => {
        const currentPath = pathname.replace(/\/$/, "");
        const linkUrl = link.url.replace(/\/$/, "");
        const isActive = currentPath === linkUrl || (linkUrl === "" && currentPath === "");

        return (
          <li>
            <a 
              href={link.url} 
              class={`block text-lg font-bold px-4 py-3 rounded-xl transition-all ${isActive ? 'bg-primary/5 text-accent pl-6 border-l-4 border-accent' : 'text-primary hover:bg-primary/5 hover:text-accent'}`}
            >
              {link.name}
            </a>
          </li>
        )
      })}
      <li class="pt-4">
        <a href="/contacto" class="block text-center w-full px-6 py-4 bg-primary text-white font-bold text-lg rounded-xl hover:bg-accent transition-colors shadow-sm">
          Contactar
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const iconOpen = document.getElementById('menu-icon-open');
    const iconClose = document.getElementById('menu-icon-close');

    if (btn && menu && iconOpen && iconClose) {
      btn.addEventListener('click', () => {
        menu.classList.toggle('hidden');
        menu.classList.toggle('flex');
        iconOpen.classList.toggle('hidden');
        iconClose.classList.toggle('hidden');
      });
    }
  });
</script>