---
// src/components/navigation/Footer.astro
import Container from '../ui/Container.astro';
import { Github, Linkedin, Mail } from 'lucide-astro';

const currentYear = new Date().getFullYear();
---

<footer class="bg-primary text-light pt-16 pb-8 border-t border-primary/20 mt-auto">
  <Container>
    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 lg:gap-12 mb-12">
      
      <div class="md:col-span-5">
        <a href="/" class="font-heading font-bold text-3xl tracking-tight mb-4 inline-block">
          Gino<span class="text-accent">.</span>
        </a>
        <p class="text-light/70 max-w-sm mt-2 text-sm md:text-base leading-relaxed">
          Estratega tecnológico. Ayudo a empresas emergentes a transformar el caos operativo en sistemas automatizados y escalables.
        </p>
      </div>

      <div class="md:col-span-4 md:col-start-7">
        <h3 class="font-heading font-semibold text-lg mb-4 text-white">Navegación</h3>
        <ul class="space-y-3 text-light/70 text-sm">
          <li><a href="/servicios" class="hover:text-accent transition-colors">Servicios Estratégicos</a></li>
          <li><a href="/proyectos" class="hover:text-accent transition-colors">Casos de Éxito</a></li>
          <li><a href="/contenido" class="hover:text-accent transition-colors">Tutoriales Técnicos</a></li>
          <li><a href="/sobre-mi" class="hover:text-accent transition-colors">Sobre Mí</a></li>
        </ul>
      </div>

      <div class="md:col-span-2">
        <h3 class="font-heading font-semibold text-lg mb-4 text-white">Conecta</h3>
        <div class="flex gap-4">
          <a href="#" class="text-light/70 hover:text-accent transition-colors" aria-label="LinkedIn"><Linkedin class="w-5 h-5"/></a>
          <a href="#" class="text-light/70 hover:text-accent transition-colors" aria-label="GitHub"><Github class="w-5 h-5"/></a>
          <a href="mailto:hola@ginocotos.com" class="text-light/70 hover:text-accent transition-colors" aria-label="Email"><Mail class="w-5 h-5"/></a>
        </div>
      </div>

    </div>

    <div class="border-t border-light/10 pt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-light/50">
      <p>&copy; {currentYear} Gino Cotos. Todos los derechos reservados.</p>
    </div>
  </Container>
</footer>