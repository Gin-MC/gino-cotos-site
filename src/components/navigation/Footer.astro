---
// Importamos los iconos de Lucide (LinkedIn e Instagram)
import { Linkedin, Instagram } from 'lucide-astro';

// Importamos tu logo desde la carpeta assets
import logo from '../../assets/logo.png';
---

<footer class="bg-primary pt-20 pb-8 text-light border-t border-light/10">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 md:gap-8 mb-16">

      <div class="col-span-1 md:col-span-2">
        <a href="/" class="inline-block mb-6 group">
          <img 
            src={logo.src} 
            alt="Gino Cotos Logo" 
            class="h-10 w-auto group-hover:scale-105 transition-transform duration-300 filter brightness-0 invert" 
          />
        </a>
        <p class="text-light/70 text-lg leading-relaxed max-w-md">
          Estratega Tecnológico B2B. Transformo el caos operativo de tu empresa en sistemas automatizados, predecibles y escalables.
        </p>
      </div>

      <div>
        <h3 class="text-accent font-bold uppercase tracking-wider text-sm mb-6">Explorar</h3>
        <ul class="space-y-4">
          <li><a href="/" class="text-light/70 hover:text-accent transition-colors font-medium">Inicio</a></li>
          <li><a href="/servicios" class="text-light/70 hover:text-accent transition-colors font-medium">Servicios</a></li>
          <li><a href="/proyectos" class="text-light/70 hover:text-accent transition-colors font-medium">Proyectos</a></li>
          <li><a href="/sobre-mi" class="text-light/70 hover:text-accent transition-colors font-medium">Sobre mí</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-accent font-bold uppercase tracking-wider text-sm mb-6">Conecta</h3>
        <ul class="space-y-4">
          <li>
            <a href="#" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 text-light/70 hover:text-accent transition-colors group font-medium">
              <Linkedin class="w-5 h-5 group-hover:scale-110 transition-transform" />
              LinkedIn
            </a>
          </li>
          <li>
            <a href="#" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 text-light/70 hover:text-accent transition-colors group font-medium">
              <Instagram class="w-5 h-5 group-hover:scale-110 transition-transform" />
              Instagram
            </a>
          </li>
          <li>
            <a href="#" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 text-light/70 hover:text-accent transition-colors group font-medium">
              <svg class="w-5 h-5 group-hover:scale-110 transition-transform fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 2.22-1.15 4.35-2.92 5.58-1.5 1.05-3.4 1.34-5.18.99-2.02-.38-3.79-1.66-4.72-3.48-1-1.95-1.02-4.32-.17-6.28 1.03-2.34 3.33-3.9 5.87-4.14v4.06c-1.22.07-2.43.61-3.14 1.58-.72.96-.86 2.31-.38 3.4.45 1.01 1.48 1.71 2.61 1.83 1.25.13 2.58-.28 3.3-1.28.62-.84.81-1.91.82-2.94.02-4.52.01-9.05.02-13.57z"/>
              </svg>
              TikTok
            </a>
          </li>
        </ul>
      </div>

    </div>

    <div class="pt-8 border-t border-light/10 flex items-center justify-center">
      <p class="text-light/50 text-sm text-center font-medium">
        &copy; 2026 Gino Cotos. Todos los derechos reservados.
      </p>
    </div>
    
  </div>
</footer>